  "scripts": {
    "backend:dev": "cd backend && npx ts-node src/main.ts",
    "backend:build": "cd backend && npx tsc",
    "backend:start": "cd backend && node dist/main.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:public": "playwright test public/",
    "test:admin": "playwright test admin/",
    "test:api": "playwright test api/",
    "test:integration": "playwright test integration/",
    "test:report": "playwright show-report",
    "test:debug": "playwright test --debug"
  },
  "directories": {
    "doc": "docs"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint . --fix"
    ]
  },
  "devDependencies": {
    "@mswjs/interceptors": "^0.41.3",
